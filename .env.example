UPSTREAM_API_BASE=https://api.example.com/v1
UPSTREAM_API_KEY=sk-replace-with-upstream-key
DOWNSTREAM_API_KEYS=sk-replace-with-user-key
MODEL_ALLOWLIST=claude-haiku-4-5-20251001,claude-sonnet-4-6,claude-opus-4-8,claude-opus-fable
# Optional identity-group config. Leave empty to keep DOWNSTREAM_API_KEYS as the legacy group.
# GATEWAY_GROUPS_JSON={"guest":{"models":["claude-haiku-4-5-20251001"],"endpoints":["models","chat.completions"],"allowStream":false,"maxInputTokens":0,"maxOutputTokens":300},"trusted":{"models":["claude-haiku-4-5-20251001","claude-sonnet-4-6"],"endpoints":["models","responses","chat.completions"],"allowStream":true,"maxInputTokens":0,"maxOutputTokens":1200}}
# GATEWAY_KEYS_JSON={"sk-user-guest":{"name":"guest user","group":"guest","enabled":true},"sk-user-trusted":{"name":"trusted user","group":"trusted","enabled":true}}
# Optional Discord signup/login. Users register or log in, then copy their key from /dashboard.
# DISCORD_CLIENT_ID=your-discord-application-client-id
# DISCORD_CLIENT_SECRET=your-discord-application-client-secret
# DISCORD_KEY_SECRET=replace-with-a-long-random-secret
# DISCORD_REDIRECT_URI=https://your-domain.example/api/auth/discord/callback
# Required for class-brain community gating.
# DISCORD_ALLOWED_GUILD_ID=optional-required-discord-server-id
# Optional resource-area gating. To restrict to a specific Discord channel/category,
# set a bot token and the resource-area channel ID. The bot must be in the server and able to read channel/member metadata.
# DISCORD_BOT_TOKEN=your-discord-bot-token
# DISCORD_RESOURCE_CHANNEL_ID=optional-resource-area-channel-id
# Optional role gates and role-to-group mapping.
# DISCORD_ALLOWED_ROLE_IDS=role-id-1,role-id-2
# DISCORD_ROLE_GROUP_MAP_JSON={"role-id-1":"guest","role-id-2":"trusted"}
# DISCORD_DEFAULT_GROUP=guest
# DISCORD_GROUP_USER_MAP_JSON={"123456789012345678":"trusted"}
# DISCORD_BLOCKED_USER_IDS=123456789012345678,234567890123456789
# GATEWAY_BLOCKED_KEY_HASHES=84a8fdc9c047,abcdef123456
# DISCORD_KEY_TTL_DAYS=30
# Registration cap. Same Discord user re-login does not consume another slot.
DISCORD_REGISTRATION_LIMIT=20
# Keep old signed Discord keys usable until their existing per-Discord-user quota runs out.
DISCORD_ALLOW_LEGACY_KEYS=true
PORT=4000
RPM_LIMIT=4
DEFAULT_KEY_BUDGET_USD=30
# 0 disables the optional per-request USD cap. Quota is still enforced by user/key budget.
MAX_REQUEST_COST_USD=0
GUEST_EXCLUDED_MODELS=claude-opus-fable
MAX_BODY_BYTES=20971520
# Optional pricing override. Defaults are:
# Opus 4.x $5/$25, Sonnet 4.x $3/$15, Haiku 4.5 $1/$5, Fable $10/$50 per 1M input/output tokens.
# MODEL_PRICES_JSON={"claude-haiku-4-5-20251001":{"input":1,"output":5}}
# Admin call-log viewer. Set a long random value in Vercel before using /admin logs.
# ADMIN_TOKEN=replace-with-a-long-random-admin-token
# CALL_LOG_LIMIT=500
# Optional durable logs for Vercel production. Vercel KV / Upstash Redis REST vars are supported.
# KV_REST_API_URL=https://...
# KV_REST_API_TOKEN=...
# CALL_LOG_KEY=gateway:call_logs
